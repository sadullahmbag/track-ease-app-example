{
  "expo": {
    "name": "TrackEase",
    "slug": "trackease-subscription-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trackease.subscriptiontracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.trackease.subscriptiontracker"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "static"
    },
    "scheme": "trackease",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}